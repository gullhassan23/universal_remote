{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "smart-tv-remote-ios",
          "appId": "1:109265895311:android:c05f88ce3b69e0fa5f55fa",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "smart-tv-remote-ios",
          "appId": "1:109265895311:ios:4cde999f7086b9c95f55fa",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "smart-tv-remote-ios",
          "configurations": {
            "android": "1:109265895311:android:c05f88ce3b69e0fa5f55fa",
            "ios": "1:109265895311:ios:4cde999f7086b9c95f55fa"
          }
        }
      }
    }
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint"
      ]
    }
  ]
}
